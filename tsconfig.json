{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["codeman/**/*.ts", "tests/**/*.ts", "packages/**/*.ts", "modules/**/*.ts"],
  "exclude": ["node_modules", "dist", "setup/output"]
}
