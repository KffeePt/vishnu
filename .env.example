# Google Sign-In / OAuth
GOOGLE_CLIENT_SECRET=
GOOGLE_WEB_CLIENT_ID=
ANDROID_SHA1=
ANDROID_SHA256=

# Admin Setup
# Vishnu / codeman Flutter-mode compatibility:
# - place admin-sdk.json in .secrets/admin-sdk.json or scripts/.secrets/admin-sdk.json (gitignored)
# - place firebase-sdk.js in .secrets/firebase-sdk.js or scripts/.secrets/firebase-sdk.js (gitignored)
OWNER_EMAIL=owner@example.com
GOOGLE_APPLICATION_CREDENTIALS=.secrets/admin-sdk.json
FIREBASE_WEB_SDK_FILE=.secrets/firebase-sdk.js

# Firebase Client (Browser API key from Google Cloud Console)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=vishnu-b65bd.firebaseapp.com
FIREBASE_PROJECT_ID=vishnu-b65bd
FIREBASE_DATABASE_URL=https://vishnu-b65bd-default-rtdb.firebaseio.com/
FIREBASE_STORAGE_BUCKET=vishnu-b65bd.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# Live Session Sync
VISHNU_SESSION_BACKEND_PROJECT_ID=vishnu-b65bd
VISHNU_SESSION_BACKEND_DATABASE_URL=https://vishnu-b65bd-default-rtdb.firebaseio.com/
VISHNU_SESSION_BACKEND_ADMIN_SDK=.secrets/admin-sdk.json
VISHNU_SESSION_TIMERS_RTDB_PATH=system/sessionTimers
VISHNU_SESSION_TIMERS_FIRESTORE_DOC=system/sessionTimers
VISHNU_SESSION_ACTIVE_SESSIONS_PATH=system/activeSessions

# Firebase App Check
APP_CHECK_WEB_RECAPTCHA_KEY=
APP_CHECK_DEBUG_TOKEN=

# MercadoPago
